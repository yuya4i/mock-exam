# ============================================================
# QuizGen 環境変数サンプル
# コピーして .env にリネームし、環境に合わせて編集してください
#   cp .env.sample .env
# ============================================================

# ---------- Ollama ----------
# Dockerコンテナ内からホストのOllamaに接続するURL
# Windows / Mac:
OLLAMA_BASE_URL=http://host.docker.internal:11434
# Linux (Dockerブリッジネットワーク経由):
# OLLAMA_BASE_URL=http://172.17.0.1:11434

# ---------- Flask ----------
# production / development
FLASK_ENV=development

# ---------- CORS ----------
# フロントエンドのオリジン（カンマ区切りで複数指定可）
CORS_ORIGINS=http://localhost:1234
