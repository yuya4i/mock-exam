# ============================================================
# QuizGen バックエンド 開発用 Dockerfile
# camoufox（Firefox ベースのアンチボット検出ブラウザ）対応
# ============================================================
FROM python:3.11-slim

WORKDIR /app

# ---- システム依存パッケージ ----
# camoufox（Firefox）の実行に必要なライブラリ群
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    wget \
    ca-certificates \
    # Firefox実行に必要なライブラリ
    libgtk-3-0 \
    libdbus-glib-1-2 \
    libxt6 \
    libxrender1 \
    libxcomposite1 \
    libxdamage1 \
    libxrandr2 \
    libgbm1 \
    libasound2 \
    libpangocairo-1.0-0 \
    libatk1.0-0 \
    libatk-bridge2.0-0 \
    libcups2 \
    libdrm2 \
    libxkbcommon0 \
    # Xvfb（仮想ディスプレイ）
    xvfb \
    x11-utils \
    # フォント
    fonts-liberation \
    fonts-noto-cjk \
    && rm -rf /var/lib/apt/lists/*

# ---- Python依存パッケージ ----
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# ---- camoufoxブラウザバイナリのダウンロード ----
# Dockerビルド時に一度だけ実行（イメージに含める）。
# fetch 完了後に UBO addon が manifest.json 付きで展開されているか
# 確認し、欠けていたら 1 回だけ再 fetch (空 dir を消して既ダウンロード
# 誤認をリセットしてから) する。詳細は Dockerfile (prod) のコメント参照。
RUN set -e; \
    python -m camoufox fetch; \
    if [ ! -f /root/.cache/camoufox/addons/UBO/manifest.json ]; then \
      echo "[fetch verify] UBO addon incomplete — clearing and retrying"; \
      rm -rf /root/.cache/camoufox/addons/UBO; \
      python -m camoufox fetch; \
    fi; \
    test -f /root/.cache/camoufox/addons/UBO/manifest.json \
      || (echo "[fetch verify] FATAL: UBO addon still missing after retry" \
          && find /root/.cache/camoufox -maxdepth 3 \
          && exit 1)

# アプリケーションコードはボリュームマウントで提供されるため COPY しない

EXPOSE 4321

# 出力バッファリングを無効化（ログ即時表示）
ENV PYTHONUNBUFFERED=1

# Werkzeug reloader は watchdog パッケージが入っていれば自動的に WatchdogReloaderLoop を使用。
# --debug は --reload を含む。--debugger はデバッガーUIを有効化。
CMD ["python", "run_dev.py", "--app", "app", "run", "--host=0.0.0.0", "--port=4321", "--debug"]
