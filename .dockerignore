# ============================================================
# Root .dockerignore
# Applied to any `docker build .` at the repository root. The
# real build contexts are `./backend` and `./frontend`, each of
# which has its own .dockerignore with stricter rules.
# ============================================================

# --- secrets (do NOT ship) ---
.env
.env.*
!.env.sample
**/secrets/
**/.ssh/
**/.aws/
**/.gcloud/

# --- VCS & tooling ---
.git/
.gitignore
.gitattributes
.github/
.claude/
.vscode/
.idea/
.DS_Store
Thumbs.db

# --- Python ---
**/__pycache__/
**/*.pyc
**/*.pyo
**/.pytest_cache/
**/.mypy_cache/
**/.ruff_cache/
**/.venv/
**/venv/

# --- Node ---
**/node_modules/
**/dist/
**/.vite/
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*

# --- project-local caches / test artifacts ---
.cache/
.playwright-mcp/
*.log

# --- docs & misc (not required at runtime) ---
docs/
SECURITY.md
assets/
screenshots/
*.md
!README.md
