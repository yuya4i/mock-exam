.env
__pycache__/
*.pyc
*.pyo
.cache/
node_modules/
dist/
*.log
.DS_Store

# テスト用一時ファイル
.playwright-mcp/
/*.png
/*.jpeg

# Playwright e2e (P2-B)
test-results/
playwright-report/
playwright/.cache/

# Host-mounted persistent data (SQLite + scrape cache).
# The directory itself is tracked via .gitkeep so a fresh clone
# already has the bind-mount target; the contents are runtime state.
/data/*
!/data/.gitkeep
